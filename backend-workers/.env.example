# ============================================
# All-in-One Tools Administrasi UMKM — Backend Workers
# ============================================

# URL dari project Supabase Anda (ditemukan di dashboard Supabase > Project Settings > API)
# Contoh: https://xyz.supabase.co
SUPABASE_URL=

# Service Role Key Supabase Anda (digunakan untuk bypass RLS di backend-workers)
# PERHATIAN: Jaga kerahasiaan kunci ini. Untuk produksi Cloudflare, gunakan `wrangler secret put`
SUPABASE_SERVICE_ROLE_KEY=

# Secret Key untuk mengenkripsi JWT Token. Bebas gunakan string acak yang panjang.
JWT_SECRET=

# Domain frontend produksi Anda (untuk mengamankan CORS). 
# Gunakan http://localhost:5173 untuk testing lokal.
ALLOWED_ORIGIN="http://localhost:5173"

# Kunci API Fonnte untuk integrasi WhatsApp Notifikasi (Fase I)
WA_API_KEY=

# Kunci API Resend untuk integrasi Email Notifikasi (Fase I)
EMAIL_API_KEY=
